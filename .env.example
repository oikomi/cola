# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Drizzle
DATABASE_URL="postgresql://postgres:password@localhost:5432/cola"

# Feishu login
# Create an internal Feishu app and set its redirect URL to:
# http://localhost:50038/api/auth/feishu/callback
# Production must use the exact public HTTPS callback URL.
# FEISHU_APP_ID="cli_xxx"
# FEISHU_APP_SECRET="xxx"
# FEISHU_REDIRECT_URI="http://localhost:50038/api/auth/feishu/callback"
# For remote deployments, set this to the browser-facing origin, for example:
# AUTH_PUBLIC_BASE_URL="http://172.16.60.198:50038"
# AUTH_SESSION_SECRET="replace-with-at-least-32-random-characters"
# Optional: comma-separated Feishu tenant keys allowed to sign in.
# AUTH_ALLOWED_TENANT_KEYS=""
# Optional: comma-separated Feishu open_ids promoted to admin on login.
# AUTH_ADMIN_FEISHU_OPEN_IDS=""
# Set true behind HTTPS in production.
# AUTH_COOKIE_SECURE="false"

# Optional: Docker OpenClaw runner provisioning
# OPENCLAW_IMAGE="ghcr.io/openclaw/openclaw:latest"
# OPENCLAW_DOCKER_COMMAND="sleep infinity"
# OPENCLAW_CONFIG_PATH="/Users/your-user/.codex/config.toml"
# OPENCLAW_AUTH_PATH="/Users/your-user/.codex/auth.json"
# OPENCLAW_WORKSPACE_ROOT="/absolute/path/to/cola"

# Optional: Docker Hermes Agent runner provisioning
# HERMES_AGENT_IMAGE="nousresearch/hermes-agent:latest"
# HERMES_DOCKER_COMMAND="sleep infinity"
# HERMES_CODEX_CONFIG_PATH="/Users/your-user/.codex/config.toml"
# HERMES_CODEX_AUTH_PATH="/Users/your-user/.codex/auth.json"
# HERMES_WORKSPACE_ROOT="/absolute/path/to/cola"
# Optional: restricted GitLab credential injected into Hermes runners.
# COLA_HERMES_GITLAB_URL="https://code.example.com"
# COLA_HERMES_GITLAB_USERNAME="oauth2"
# COLA_HERMES_GITLAB_TOKEN="glpat-xxx"
# COLA_HERMES_GITLAB_SECRET_NAME="existing-k8s-secret"
# Optional: Feishu group bot for Hermes task results.
# COLA_HERMES_FEISHU_WEBHOOK_URL="https://open.feishu.cn/open-apis/bot/v2/hook/xxx"
# COLA_HERMES_FEISHU_WEBHOOK_SECRET="optional-signing-secret"

# Shared Docker runner settings
# COLA_API_BASE_URL="http://host.docker.internal:50038"
# COLA_RUNNER_HOST="host.docker.internal"
# COLA_DASHBOARD_BIND_HOST="127.0.0.1"
# COLA_OPENCLAW_DASHBOARD_PUBLIC_HOST="openclaw.example.com"
# COLA_HERMES_DASHBOARD_PUBLIC_HOST="hermes.example.com"
# COLA_DASHBOARD_ALLOWED_ORIGINS="https://cola.example.com,https://openclaw.example.com"
# COLA_OPENCLAW_DISABLE_DEVICE_IDENTITY="0"

# Optional: native OpenClaw / Hermes pages opened in a new browser window.
# Supported placeholders: {agentId} {deviceId} {engine}
# For remote deployment, set these to public URLs instead of localhost.
# NEXT_PUBLIC_OPENCLAW_NATIVE_URL="https://openclaw.example.com/"
# NEXT_PUBLIC_HERMES_NATIVE_URL="https://hermes.example.com/"
# Optional: system management redirect target. If omitted, `/system` falls back to
# `https://<current-host>:8443/`.
# NEXT_PUBLIC_K8S_DASHBOARD_URL="https://k8s-dashboard.example.com/"

# Kubernetes training runtime
# COLA_TRAINING_RUNTIME_CLASS_NAME="nvidia"
# SeaweedFS Filer/FUSE is mounted automatically into remote desktop, training
# Job, JupyterLab and Unsloth Studio pods as a normal filesystem workdir.
# The cluster in infra/k8s/cluster uses Kubernetes 1.34, so restartable init
# sidecars are available and Jobs can still complete after the main container exits.
# COLA_SEAWEEDFS_MOUNT_ENABLED="true"
# COLA_SEAWEEDFS_IMAGE="chrislusf/seaweedfs:4.23"
# COLA_SEAWEEDFS_IMAGE_PULL_POLICY="IfNotPresent"
# COLA_SEAWEEDFS_FILER="seaweedfs-filer.storage.svc.cluster.local:8888"
# COLA_SEAWEEDFS_FILER_PATH="/buckets/cola-training"
# COLA_SEAWEEDFS_CACHE_CAPACITY_MB="4096"
# COLA_SEAWEEDFS_CHUNK_SIZE_LIMIT_MB="32"
# COLA_SEAWEEDFS_ALLOW_OTHERS="true"
# COLA_SEAWEEDFS_MOUNT_UID="1000"
# COLA_SEAWEEDFS_MOUNT_GID="1000"
# COLA_SEAWEEDFS_MOUNT_UMASK="000"
# Optional: use filerProxy only when volume server addresses are not directly reachable.
# COLA_SEAWEEDFS_VOLUME_SERVER_ACCESS="filerProxy"
# COLA_TRAINING_WORKDIR_MOUNT_PATH="/workspace"
# REMOTE_WORKSPACE_WORKDIR_MOUNT_PATH="/workspace"
# COLA_JUPYTERLAB_WORKDIR_MOUNT_PATH="/workspace"
# COLA_UNSLOTH_STUDIO_WORKDIR_MOUNT_PATH="/workspace"
# Optional legacy fallback. Set COLA_SEAWEEDFS_MOUNT_ENABLED=false before using hostPath/PVC.
# COLA_TRAINING_WORKDIR_HOST_PATH="/mnt/cola-training"
# COLA_TRAINING_PVC_NAME="cola-training-workspace"
# COLA_JUPYTERLAB_PVC_NAME="cola-jupyterlab-workspace"
# COLA_JUPYTERLAB_WORKDIR_HOST_PATH="/mnt/cola-training"
# COLA_UNSLOTH_STUDIO_WORKDIR_HOST_PATH="/mnt/cola-training"
# REMOTE_WORKSPACE_WORKDIR_HOST_PATH="/mnt/cola-training"
# Optional: comma-separated label=image list, capped at 5 choices.
# COLA_JUPYTERLAB_IMAGE_OPTIONS="PyTorch CPU=quay.io/jupyter/pytorch-notebook:latest,PyTorch CUDA 12=quay.io/jupyter/pytorch-notebook:cuda12-latest,PyTorch CUDA 13=quay.io/jupyter/pytorch-notebook:cuda13-latest"
# COLA_TRAINING_K8S_IMAGE="docker.io/library/cola-training-deepspeed:local"
# COLA_TRAINING_IMAGE_PULL_POLICY="Never"



