# Optional overrides for deploy.sh.
# 复制为 juicefs.env 后再修改：
#   cp juicefs.env.example juicefs.env
#   vim juicefs.env
#
# 不要提交真实 juicefs.env；这里可能包含对象存储 AK/SK、Redis 密码等敏感信息。

# Kubernetes objects.
# CSI Driver 安装到哪个 namespace。默认 kube-system。
JUICEFS_CSI_NAMESPACE=kube-system

# Helm release 名称。一般不用改；重复执行 deploy.sh 会 upgrade 这个 release。
JUICEFS_RELEASE=juicefs-csi-driver

# JuiceFS Secret 放在哪个 namespace。
# StorageClass 里会引用这个 Secret，CSI Controller 和 Node Publish 都会读取它。
JUICEFS_SECRET_NAMESPACE=kube-system

# JuiceFS Secret 名称。一般不用改。
JUICEFS_SECRET_NAME=juicefs-secret

# Kubernetes StorageClass 名称。
# 训练平台创建 PVC 时通常会把 storageClassName 填成这个值，例如 juicefs-sc。
JUICEFS_STORAGECLASS_NAME=juicefs-sc

# 是否把这个 StorageClass 设置为集群默认 StorageClass。
# 0 = 不设置默认；1 = 设置默认。生产环境建议谨慎开启，避免影响其他 PVC。
JUICEFS_SET_DEFAULT_STORAGECLASS=0

# PVC 删除后底层 PV 的回收策略。
# Retain = 保留数据，适合训练数据/checkpoint；Delete = 删除 PV 时清理底层数据。
JUICEFS_RECLAIM_POLICY=Retain

# 是否允许 PVC 扩容。
# true 后可以把 500Gi PVC 扩到更大；是否真正生效还取决于 CSI 和后端能力。
JUICEFS_ALLOW_VOLUME_EXPANSION=true

# Recommended backend: SeaweedFS S3 from ../seaweedfs.
#
# 推荐方式：
#   1. 先部署 ../seaweedfs
#   2. 执行 ../seaweedfs/deploy.sh render-juicefs-env --env-file seaweedfs.env
#   3. 把输出写入本文件对应变量
#
# 示例：
# JUICEFS_LOCAL_BACKEND=0
# JUICEFS_METADATA_REDIS=1
# JUICEFS_METADATA_REDIS_NAMESPACE=storage
# JUICEFS_METADATA_REDIS_NAME=juicefs-redis
# JUICEFS_METAURL=redis://juicefs-redis.storage.svc.cluster.local:6379/1
# JUICEFS_STORAGE=s3
# JUICEFS_BUCKET=http://seaweedfs-s3.storage.svc.cluster.local:8333/cola-juicefs
# JUICEFS_ACCESS_KEY=seaweedfs
# JUICEFS_SECRET_KEY=seaweedfs-secret
#
# Legacy local backend: deploy Redis and MinIO inside Kubernetes and store their data
# on one node's local disk through hostPath.
#
# 默认模式说明：
# - JUICEFS_LOCAL_BACKEND=1 时，deploy.sh 会在集群里部署 Redis + MinIO。
# - Redis 保存 JuiceFS 元数据。
# - MinIO 保存 JuiceFS 文件数据块。
# - Redis/MinIO 的真实数据落在某个 worker 节点的本地目录。
# - 这个模式只是 legacy/local 测试路径；不建议作为训练平台长期存储。
JUICEFS_LOCAL_BACKEND=1

# 只部署 JuiceFS metadata Redis，不部署 legacy MinIO。
# SeaweedFS + JuiceFS 推荐设置：
#   JUICEFS_LOCAL_BACKEND=0
#   JUICEFS_METADATA_REDIS=1
JUICEFS_METADATA_REDIS=0
JUICEFS_METADATA_REDIS_NAMESPACE=storage
JUICEFS_METADATA_REDIS_NAME=juicefs-redis
JUICEFS_METADATA_REDIS_NODE_NAME=
JUICEFS_METADATA_REDIS_ROOT=/var/lib/cola/juicefs
JUICEFS_METADATA_REDIS_IMAGE=redis:7-alpine

# Redis/MinIO 部署到哪个 namespace。
JUICEFS_LOCAL_BACKEND_NAMESPACE=storage

# Leave empty to auto-pick the first non-master worker from ../k8s/cluster/nodes.json.
# 指定 Redis/MinIO 固定落盘的 Kubernetes 节点名。
# 留空时脚本会从 ../k8s/cluster/nodes.json 自动选择第一个非 master worker。
# 如果你明确知道哪台机器硬盘大，建议填具体节点名，例如 node-01。
JUICEFS_LOCAL_BACKEND_NODE_NAME=

# Redis/MinIO 在目标节点上的 hostPath 根目录。
# 实际会使用：
#   /var/lib/cola/juicefs/redis
#   /var/lib/cola/juicefs/minio
JUICEFS_LOCAL_BACKEND_ROOT=/var/lib/cola/juicefs

# 集群内 Redis Deployment/Service 名称。
JUICEFS_LOCAL_BACKEND_REDIS_NAME=juicefs-redis

# Redis 镜像。离线或私有镜像仓库环境可改成内网镜像。
JUICEFS_LOCAL_BACKEND_REDIS_IMAGE=redis:7-alpine

# 集群内 MinIO Deployment/Service 名称。
JUICEFS_LOCAL_BACKEND_MINIO_NAME=juicefs-minio

# MinIO 服务端镜像。离线或私有镜像仓库环境可改成内网镜像。
JUICEFS_LOCAL_BACKEND_MINIO_IMAGE=minio/minio:RELEASE.2025-04-22T22-12-26Z

# MinIO Client 镜像，用来初始化 bucket。
JUICEFS_LOCAL_BACKEND_MC_IMAGE=minio/mc:RELEASE.2025-04-16T18-13-26Z

# MinIO bucket 名称。JuiceFS 文件数据块会写到这个 bucket。
JUICEFS_LOCAL_BACKEND_BUCKET=cola-juicefs

# 本地 MinIO root 用户名。
# 这是凭据，真实环境建议改掉默认值。
JUICEFS_LOCAL_BACKEND_ACCESS_KEY=minioadmin

# 本地 MinIO root 密码。
# 这是凭据，真实环境必须改掉默认值。
JUICEFS_LOCAL_BACKEND_SECRET_KEY=minioadmin

# JuiceFS volume identity and backend.
# JuiceFS 文件系统名称。会作为 juicefs format 的 name。
# 训练平台不直接使用这个名字；训练平台通常使用 PVC 名称和 StorageClass 名称。
JUICEFS_NAME=cola-juicefs

# 元数据引擎地址。
# 本地后端模式下可留空，脚本会自动填：
#   redis://juicefs-redis.storage.svc.cluster.local:6379/1
#
# Examples:
#   redis://:password@redis.example.com:6379/1
#   mysql://user:password@(mysql.example.com:3306)/juicefs
#   postgresql://user:password@postgres.example.com:5432/juicefs
JUICEFS_METAURL=

# 对象存储类型。
# 本地后端模式下可留空，脚本会自动填 minio。
# 外部存储常见值：s3、oss、cos、obs、minio。
JUICEFS_STORAGE=

# 对象存储 bucket 地址。
# 本地后端模式下可留空，脚本会自动填：
#   http://juicefs-minio.storage.svc.cluster.local:9000/cola-juicefs
JUICEFS_BUCKET=

# 对象存储访问 Key。
# 本地后端模式下可留空，脚本会使用 JUICEFS_LOCAL_BACKEND_ACCESS_KEY。
JUICEFS_ACCESS_KEY=

# 对象存储访问 Secret。
# 本地后端模式下可留空，脚本会使用 JUICEFS_LOCAL_BACKEND_SECRET_KEY。
JUICEFS_SECRET_KEY=

# External object storage examples when JUICEFS_LOCAL_BACKEND=0:
# 如果要使用外部对象存储，不在集群里部署 Redis/MinIO：
#   1. 设置 JUICEFS_LOCAL_BACKEND=0
#   2. 填 JUICEFS_METAURL
#   3. 填 JUICEFS_STORAGE、JUICEFS_BUCKET、JUICEFS_ACCESS_KEY、JUICEFS_SECRET_KEY
#
# Examples:
#   storage=s3, bucket=https://bucket.s3.region.amazonaws.com
#   storage=oss, bucket=https://bucket.oss-cn-hangzhou.aliyuncs.com
#   storage=minio, bucket=http://minio.minio.svc.cluster.local:9000/bucket

# Set to 1 when this JuiceFS volume has already been formatted elsewhere.
# In that case storage/bucket credentials are not required by this script.
# 0 = 让 CSI/Secret 包含 format 所需参数，新集群首次部署通常用 0。
# 1 = 文件系统已经在外部格式化过，只挂载已有 JuiceFS volume。
JUICEFS_EXISTING_VOLUME=0

# Optional JuiceFS format and mount options.
# 传给 juicefs format 的额外参数。
# 例如保留回收站 7 天：
# JUICEFS_FORMAT_OPTIONS=--trash-days=7
#
# StorageClass mountOptions，逗号分隔。
# cache-size 单位通常是 MiB；示例表示每个挂载点缓存 10240 MiB。
# JUICEFS_MOUNT_OPTIONS=cache-size=10240,free-space-ratio=0.1

# Optional Helm chart pinning.
# 固定 JuiceFS CSI Driver chart 版本。留空则使用 Helm repo 当前可用版本。
# JUICEFS_CHART_VERSION=

# Helm values 文件路径。默认使用当前目录 values.yaml。
# JUICEFS_HELM_VALUES=./values.yaml
