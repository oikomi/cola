# Harbor deployment settings for the Cola Kubernetes cluster.
#
# Copy this file to harbor.env and change every password before install:
#
#   cp harbor.env.example harbor.env
#   vim harbor.env

HARBOR_NAMESPACE=registry
HARBOR_RELEASE=harbor

# User requested Harbor v2.14.4. The script pins all Harbor component images to
# this tag. HARBOR_CHART_VERSION is the harbor-helm chart version; keep it
# explicit so upgrades are intentional.
HARBOR_IMAGE_TAG=v2.14.4
HARBOR_CHART_VERSION=1.18.3
HARBOR_EXPOSE_TYPE=nodePort

# LAN entrypoint. controllerIp must come from infra/k8s/cluster/config.json.
HARBOR_HTTP_NODE_PORT=32248
HARBOR_HTTPS_NODE_PORT=32249
HARBOR_EXTERNAL_URL=http://172.16.60.198:32248

# Harbor chart-internal TLS is disabled by default for simple LAN deployment.
# If you enable it, update HARBOR_EXTERNAL_URL to https://... and configure
# certificates according to harbor-helm.
HARBOR_EXPOSE_TLS_ENABLED=false

# Required secrets. Replace before real deployment.
HARBOR_ADMIN_PASSWORD=change-me-before-deploy
HARBOR_SECRET_KEY=not-a-secure-secret-key
HARBOR_REGISTRY_CREDENTIAL_USERNAME=harbor_registry_user
HARBOR_REGISTRY_CREDENTIAL_PASSWORD=change-me-registry-password

# Persistence. Set HARBOR_STORAGE_CLASS to cola-cephfs/cola-rbd/etc. after a
# working StorageClass exists, or leave empty to use the cluster default.
HARBOR_PERSISTENCE_ENABLED=true
HARBOR_STORAGE_CLASS=
HARBOR_REGISTRY_SIZE=200Gi
HARBOR_JOB_SERVICE_SIZE=5Gi
HARBOR_DATABASE_SIZE=10Gi
HARBOR_REDIS_SIZE=5Gi
HARBOR_TRIVY_SIZE=10Gi

HARBOR_TRIVY_ENABLED=true
HARBOR_NOTARY_ENABLED=false
HARBOR_CHARTMUSEUM_ENABLED=false
HARBOR_REPLICAS=1
