# Optional overrides for deploy.sh.
# 复制为 seaweedfs.env 后再修改：
#   cp seaweedfs.env.example seaweedfs.env
#   vim seaweedfs.env
#
# 不要提交真实 seaweedfs.env；这里包含 S3 access key / secret key。

# Kubernetes objects.
# SeaweedFS 默认部署在 storage namespace。
SEAWEEDFS_NAMESPACE=storage

# Helm release 名称。
SEAWEEDFS_RELEASE=seaweedfs

# SeaweedFS 官方 Helm chart 仓库。
SEAWEEDFS_HELM_REPO_NAME=seaweedfs
SEAWEEDFS_HELM_REPO_URL=https://seaweedfs.github.io/seaweedfs/helm
SEAWEEDFS_CHART=seaweedfs/seaweedfs

# Helm chart/image 版本。
# 默认固定到已验证存在的 4.26，避免 Helm 仓库发布领先 Docker 镜像时拉取不存在的镜像 tag。
SEAWEEDFS_CHART_VERSION=4.26.0
SEAWEEDFS_IMAGE_REPOSITORY=chrislusf/seaweedfs
SEAWEEDFS_IMAGE_TAG=4.26

# 部署前把 SeaweedFS 和 bucket/smoke-test 辅助镜像预热到 Kubernetes 节点的 containerd。
# 当前局域网如果被代理或证书劫持，节点直接拉 Docker Hub 可能失败；
# install 会默认先执行预热，也可单独运行 ./deploy.sh prewarm-images。
SEAWEEDFS_PREWARM_IMAGES=true
# 默认预热 infra/k8s/cluster/nodes.json 里的全部节点。需要缩小范围时用逗号或空格分隔。
# SEAWEEDFS_PREWARM_TARGET_NODES=master-01,node-01

# Helm 等待超时时间。
SEAWEEDFS_WAIT_TIMEOUT=600s

# 本地数据目录。
# 当前集群只有系统盘时，这个目录会落在根分区上，只适合测试/临时使用。
# 如果后续加了独立数据盘，应把独立盘挂载到这个路径或改成独立盘路径。
SEAWEEDFS_DATA_ROOT=/var/lib/cola/seaweedfs

# Master / Filer / S3 / Admin 都使用节点本地 hostPath 保存元数据或日志。
# 单副本部署时必须固定到同一个 Kubernetes 节点，否则节点重启后 Pod 漂移到
# 另一台机器会读到空的 metadata 目录，看起来就像 xdream bucket 丢了。
# 当前已有 bucket 元数据在 node-01 上，因此默认固定到 node-01。
# 只有改成共享 PVC 或迁移 metadata 后，才应改这里。
SEAWEEDFS_METADATA_NODE=node-01

# 是否启用 SeaweedFS 安全配置。
# external NAS volume 模式下，裸机 weed volume 也需要同一套安全配置。
# 当前 nas.sh 默认在可信局域网测试场景设为 false，避免外部 volume 无法注册。
SEAWEEDFS_ENABLE_SECURITY=true

# Volume server 模式：
# - k8s：在 Kubernetes 内创建 SeaweedFS volume Pod。
# - external：不创建 volume Pod，由 NAS 裸机运行 weed volume。
SEAWEEDFS_VOLUME_MODE=k8s

# 存储节点配置，JSON array。
# node 必须是 Kubernetes node name。
# path 是该节点上用于 SeaweedFS volume server 的 hostPath。
# 当前 Helm values 使用第一个 path 作为所有 volume Pod 的 hostPath 模板。
# 因此建议每台节点都使用同一个目录路径，例如 /var/lib/cola/seaweedfs/volume。
#
# 你当前只有 master-01 和 node-01，且都没有独立数据盘。
# 下面这种配置能跑测试，但不是生产级可靠存储。
SEAWEEDFS_VOLUME_NODES='[
  {"name":"master-01","path":"/var/lib/cola/seaweedfs/volume"},
  {"name":"node-01","path":"/var/lib/cola/seaweedfs/volume"}
]'

# 副本策略。
# 000 = 单副本，容量利用最高，没有容错。
# 001 = 在不同 rack 再放 1 份副本；两节点测试通常用它。
# 更多策略参考 SeaweedFS replication 文档。
SEAWEEDFS_REPLICATION=000

# Master / Filer / S3 gateway 副本数。
# 两节点测试可以 1；生产建议至少 3 个 master。
SEAWEEDFS_MASTER_REPLICAS=1
SEAWEEDFS_FILER_REPLICAS=1
SEAWEEDFS_S3_REPLICAS=1

# Volume server 每个 Pod 的最大 volume 数。
# 容量粗略上限约为 maxVolumes * master.volumeSizeLimitMB。
SEAWEEDFS_VOLUME_MAX=100
SEAWEEDFS_VOLUME_SIZE_LIMIT_MB=30000

# external volume 模式需要把 SeaweedFS master 暴露给 NAS 注册。
# weed volume 的 -master 使用 <host>:<httpNodePort>.<grpcNodePort> 格式。
SEAWEEDFS_MASTER_PORT=9333
SEAWEEDFS_MASTER_GRPC_PORT=19333
SEAWEEDFS_MASTER_NODEPORT_ENABLED=false
SEAWEEDFS_MASTER_NODEPORT_SERVICE_NAME=seaweedfs-master-nodeport
SEAWEEDFS_MASTER_NODE_PORT=32333
SEAWEEDFS_MASTER_GRPC_NODE_PORT=32334
# 默认使用 infra/k8s/cluster/config.json 的 controllerIp。
# SEAWEEDFS_MASTER_EXTERNAL_HOST=172.16.60.198

# external NAS volume 参数。直接使用 deploy.sh 时需要手动配置；
# 使用 ./nas.sh 时会优先从 infra/k8s/cluster/nas.json 自动推导。
# SEAWEEDFS_EXTERNAL_VOLUME_IP=172.16.60.47
SEAWEEDFS_EXTERNAL_VOLUME_WEED_BIN=/volume1/cola/seaweedfs/bin/weed
SEAWEEDFS_EXTERNAL_VOLUME_DIR=/volume1/cola/seaweedfs/volume
SEAWEEDFS_EXTERNAL_VOLUME_PORT=8080
SEAWEEDFS_EXTERNAL_VOLUME_GRPC_PORT=18080
# 0 表示让 SeaweedFS 按磁盘空闲空间和 volumeSizeLimitMB 自动计算 volume 数。
SEAWEEDFS_EXTERNAL_VOLUME_MAX=0
SEAWEEDFS_EXTERNAL_VOLUME_MIN_FREE_SPACE=100GiB
SEAWEEDFS_EXTERNAL_VOLUME_DATA_CENTER=xdream
SEAWEEDFS_EXTERNAL_VOLUME_RACK=nas
SEAWEEDFS_EXTERNAL_VOLUME_DISK=hdd
SEAWEEDFS_EXTERNAL_VOLUME_INDEX=leveldbMedium

# S3 gateway。
# 纯 SeaweedFS 方案主要通过这个 S3 endpoint 给训练平台、JupyterLab、
# Unsloth Studio 或数据导入工具使用。
SEAWEEDFS_S3_ENABLED=true
SEAWEEDFS_S3_SERVICE_NAME=seaweedfs-s3
SEAWEEDFS_S3_PORT=8333
SEAWEEDFS_S3_BUCKET=xdream

# 是否额外创建 S3 NodePort，给局域网内其他机器访问。
# 集群内训练任务仍然优先使用 seaweedfs-s3.storage.svc.cluster.local。
# 默认局域网访问地址按 infra/k8s/cluster/config.json 里的 controllerIp 计算：
#   http://172.16.60.198:32247
SEAWEEDFS_S3_NODEPORT_ENABLED=true
SEAWEEDFS_S3_NODEPORT_SERVICE_NAME=seaweedfs-s3-nodeport
SEAWEEDFS_S3_NODE_PORT=32247

# S3 访问凭据。真实环境必须改掉默认值。
SEAWEEDFS_S3_ACCESS_KEY=seaweedfs
SEAWEEDFS_S3_SECRET_KEY=seaweedfs-secret

# 官方 Admin UI。
# deploy.sh 会启用 chart 里的 weed admin，并额外创建一个 NodePort Service。
# 默认访问地址按 infra/k8s/cluster/config.json 里的 controllerIp 计算：
#   http://172.16.60.198:32246
SEAWEEDFS_ADMIN_ENABLED=true
SEAWEEDFS_ADMIN_SERVICE_NAME=seaweedfs-admin-ui
SEAWEEDFS_ADMIN_USER=admin
SEAWEEDFS_ADMIN_PASSWORD=123456
SEAWEEDFS_ADMIN_NODE_PORT=32246
SEAWEEDFS_ADMIN_TARGET_PORT=23646
SEAWEEDFS_ADMIN_GRPC_PORT=33646

# 是否创建一个 bucket 初始化 Job。
SEAWEEDFS_CREATE_BUCKET_JOB=1

# bucket 初始化 Job 使用的 aws-cli 镜像。
SEAWEEDFS_BUCKET_JOB_IMAGE=amazon/aws-cli:2.17.50

# smoke-test 会在集群内通过 S3 API 上传、下载并校验一个小文件。
SEAWEEDFS_SMOKE_TEST_JOB=seaweedfs-s3-smoke-test
SEAWEEDFS_SMOKE_TEST_IMAGE=amazon/aws-cli:2.17.50
