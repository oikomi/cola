# Optional overrides for deploy.sh.
# 复制为 seaweedfs-juicefs.env 后再修改：
#   cp seaweedfs-juicefs.env.example seaweedfs-juicefs.env
#   vim seaweedfs-juicefs.env
#
# 不要提交真实 seaweedfs-juicefs.env；这里包含 S3 access key / secret key。

# Kubernetes namespace.
# SeaweedFS 和 JuiceFS metadata Redis 默认放在 storage。
STORAGE_NAMESPACE=storage

# 当前集群只有 master-01 和 node-01，且都只有系统盘。
# 下面配置可以先跑通，但不是生产级可靠存储。
# path 建议在所有节点保持同一路径。后续加独立数据盘后，把数据盘挂到这个路径。
SEAWEEDFS_VOLUME_NODES='[
  {"name":"master-01","path":"/var/lib/cola/seaweedfs/volume"},
  {"name":"node-01","path":"/var/lib/cola/seaweedfs/volume"}
]'

# SeaweedFS Helm chart.
SEAWEEDFS_RELEASE=seaweedfs
SEAWEEDFS_HELM_REPO_NAME=seaweedfs
SEAWEEDFS_HELM_REPO_URL=https://seaweedfs.github.io/seaweedfs/helm
SEAWEEDFS_CHART=seaweedfs/seaweedfs
# SEAWEEDFS_CHART_VERSION=
SEAWEEDFS_WAIT_TIMEOUT=600s

# SeaweedFS data and topology.
SEAWEEDFS_DATA_ROOT=/var/lib/cola/seaweedfs
SEAWEEDFS_REPLICATION=001
SEAWEEDFS_MASTER_REPLICAS=1
SEAWEEDFS_FILER_REPLICAS=1
SEAWEEDFS_S3_REPLICAS=1
SEAWEEDFS_VOLUME_MAX=100

# SeaweedFS S3 gateway.
SEAWEEDFS_S3_SERVICE_NAME=seaweedfs-s3
SEAWEEDFS_S3_PORT=8333
SEAWEEDFS_S3_BUCKET=cola-juicefs

# S3 凭据。真实环境必须修改默认值。
SEAWEEDFS_S3_ACCESS_KEY=seaweedfs
SEAWEEDFS_S3_SECRET_KEY=seaweedfs-secret

# JuiceFS metadata Redis.
# 这只保存 JuiceFS 元数据，文件数据块放在 SeaweedFS S3。
JUICEFS_METADATA_REDIS_NAME=juicefs-redis
JUICEFS_METADATA_REDIS_NODE_NAME=node-01
JUICEFS_METADATA_REDIS_ROOT=/var/lib/cola/juicefs
JUICEFS_METADATA_REDIS_IMAGE=redis:7-alpine

# JuiceFS CSI.
JUICEFS_RELEASE=juicefs-csi-driver
JUICEFS_REPO_NAME=juicefs
JUICEFS_REPO_URL=https://juicedata.github.io/charts/
JUICEFS_CHART_REF=juicefs/juicefs-csi-driver
# JUICEFS_CHART_VERSION=
JUICEFS_HELM_VALUES=../juicefs/values.yaml
JUICEFS_WAIT_TIMEOUT=600s

# JuiceFS Secret and StorageClass.
JUICEFS_SECRET_NAMESPACE=kube-system
JUICEFS_SECRET_NAME=juicefs-secret
JUICEFS_NAME=cola-juicefs
JUICEFS_STORAGECLASS_NAME=juicefs-sc
JUICEFS_SET_DEFAULT_STORAGECLASS=0
JUICEFS_RECLAIM_POLICY=Retain
JUICEFS_ALLOW_VOLUME_EXPANSION=true

# Optional JuiceFS format and mount options.
# JUICEFS_FORMAT_OPTIONS=--trash-days=7
# JUICEFS_MOUNT_OPTIONS=cache-size=10240,free-space-ratio=0.1

# Training workspace PVC.
CREATE_TRAINING_PVC=1
TRAINING_NAMESPACE=remote-work
TRAINING_PVC_NAME=cola-training-workspace
TRAINING_PVC_SIZE=500Gi
