# Optional overrides for deploy.sh.
# 复制为 rook-ceph.env 后再修改：
#   cp rook-ceph.env.example rook-ceph.env
#   vim rook-ceph.env
#
# 不要把真实生产磁盘规划、凭据或内部仓库地址提交到 git。

# Kubernetes objects.
# Rook Operator 和 CephCluster 默认放在同一个 namespace。
ROOK_CEPH_NAMESPACE=rook-ceph

# Helm release 名称。重复执行 deploy.sh 会 upgrade 这些 release。
ROOK_OPERATOR_RELEASE=rook-ceph
ROOK_CLUSTER_RELEASE=rook-ceph-cluster

# Helm repo 和 chart。
ROOK_HELM_REPO_NAME=rook-release
ROOK_HELM_REPO_URL=https://charts.rook.io/release
ROOK_OPERATOR_CHART=rook-release/rook-ceph
ROOK_CLUSTER_CHART=rook-release/rook-ceph-cluster

# 可选：固定 Rook chart 版本。留空则使用 Helm repo 当前版本。
# 生产环境建议固定版本并先在测试集群验证升级流程。
# ROOK_CHART_VERSION=

# Helm 等待超时时间。
ROOK_WAIT_TIMEOUT=900s

# CephCluster 基本配置。
# CephCluster 资源名称。一般不用改。
ROOK_CEPH_CLUSTER_NAME=rook-ceph

# Ceph 镜像。必须和 Rook 支持矩阵兼容。
# 如果你的集群不能访问 quay.io，需要改成内网镜像。
ROOK_CEPH_IMAGE=quay.io/ceph/ceph:v19.2.3

# 是否允许调度到 master/control-plane 节点。
# 0 = 只建议 worker 节点；1 = 允许包含 master。
ROOK_ALLOW_MASTER_NODES=0

# OSD 数据盘配置。
# 强烈建议使用裸盘或专用数据盘，不要使用系统盘目录。
#
# ROOK_STORAGE_USE_ALL_NODES:
#   0 = 只使用 ROOK_STORAGE_NODES 显式列出的节点。
#   1 = 允许 Rook 在所有可调度节点上发现设备。
#
# ROOK_STORAGE_USE_ALL_DEVICES:
#   0 = 只使用每个节点 devices 列出的磁盘。
#   1 = 使用节点上所有可用裸盘。生产环境谨慎开启。
ROOK_STORAGE_USE_ALL_NODES=0
ROOK_STORAGE_USE_ALL_DEVICES=0

# 显式节点和磁盘列表，JSON 格式。
# 节点名必须和 Kubernetes node name 一致，可用 kubectl get nodes 查看。
# devices.name 填 Linux 设备名，例如 sdb、nvme1n1，不要写 /dev/sdb。
#
# 示例：
# ROOK_STORAGE_NODES='[
#   {"name":"node-01","devices":[{"name":"sdb"}]},
#   {"name":"node-02","devices":[{"name":"sdb"}]},
#   {"name":"node-03","devices":[{"name":"sdb"}]}
# ]'
ROOK_STORAGE_NODES=[]

# Ceph 副本数。
# 3 = 三副本，建议至少 3 个存储节点；可容忍 1 个节点/盘故障。
# 2 = 两副本，只适合测试或容量压力很大但可靠性要求较低的环境。
ROOK_REPLICATED_SIZE=3

# Ceph MON 数量。生产建议 3 或 5，且不要超过可用节点数。
ROOK_MON_COUNT=3

# Ceph Dashboard。
ROOK_DASHBOARD_ENABLED=true
ROOK_DASHBOARD_SSL=false

# StorageClass names.
# 训练平台共享工作空间建议使用 CephFS，因为它支持 ReadWriteMany。
ROOK_CEPHFS_STORAGECLASS=cola-cephfs

# 普通单 Pod 块存储使用 RBD，访问模式通常是 ReadWriteOnce。
ROOK_RBD_STORAGECLASS=cola-rbd

# 是否把 CephFS/RBD 设为默认 StorageClass。
# 生产环境谨慎开启，避免影响已有 PVC。
ROOK_CEPHFS_DEFAULT_STORAGECLASS=0
ROOK_RBD_DEFAULT_STORAGECLASS=0

# 训练平台 PVC 模板。
# deploy.sh 默认只渲染模板；如要自动创建，把 ROOK_CREATE_TRAINING_PVC=1。
ROOK_CREATE_TRAINING_PVC=0
ROOK_TRAINING_NAMESPACE=remote-work
ROOK_TRAINING_PVC_NAME=cola-training-workspace
ROOK_TRAINING_PVC_SIZE=500Gi
