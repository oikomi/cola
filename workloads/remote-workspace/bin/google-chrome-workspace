#!/usr/bin/env bash

set -euo pipefail

export HOME="${HOME:-/home/worker}"
mkdir -p "$HOME/.config/google-chrome" "$HOME/Downloads"

exec /usr/bin/google-chrome-stable \
  --no-sandbox \
  --disable-dev-shm-usage \
  --ozone-platform=x11 \
  --user-data-dir="${CHROME_USER_DATA_DIR:-$HOME/.config/google-chrome}" \
  "$@"
